<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_change_password_wizard_form" model="ir.ui.view">
        <field name="name">user.change.password.form</field>
        <field name="model">user.change.password</field>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <form string="Change Password">
                <group>
                    <field name="old_password" password="True"/>
                    <field name="new_password" password="True"/>
                    <field name="confirm_password" password="True"/>
                </group>
                <footer>
                    <button string="Change Password" type="object" name="action_change_password" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_change_password_wizard" model="ir.actions.act_window">
        <field name="name">Change Password</field>
        <field name="res_model">user.change.password</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>