<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Shared layout used by every letter type -->
    <template id="letter_layout">
    <div class="letter-layout" style="padding: 30px; font-family: sans-serif;">
        <div class="letter-header" style="display:flex; align-items:center; border-bottom:1px solid #ddd; padding-bottom:10px; margin-bottom:20px;">
            <t t-if="company.logo">
                <img t-att-src="image_data_uri(company.logo)" style="max-height:60px; margin-right:15px;"/>
            </t>
            <div>
                <div style="font-weight:bold; font-size:16px;" t-out="company.name"/>
                <div style="font-size:12px; color:#555;" t-out="company.partner_id.contact_address_inline"/>
            </div>
        </div>

        <div class="letter-body">
            <t t-out="0"/>
        </div>

        <div class="letter-footer" style="margin-top:40px; font-size:11px; color:#777; border-top:1px solid #ddd; padding-top:10px;">
            <span t-out="company.name"/> — Generated on <span t-out="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/>
        </div>
    </div>
</template>


    <!-- Per-type body templates: t-call the shared layout, fill in type-specific text -->
    <template id="letter_body_appointment">
        <t t-call="employee_letter_wizard.letter_layout">
            <p>Date: <span t-out="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y')"/></p>
            <p>Dear <span t-out="employee.name"/>,</p>
            <p>
                We are pleased to appoint you as
                <b t-out="employee.job_title or employee.job_id.name"/>
                in the <b t-out="employee.department_id.name"/> department at
                <span t-out="company.name"/>, effective from
                <t t-if="joining_date">
                    <span t-out="joining_date.strftime('%d-%m-%Y')"/>.
                </t>
                <t t-else="">
                    your joining date.
                </t>
            </p>
            <p>
                This letter confirms your appointment subject to the terms and conditions
                discussed with you. We look forward to a successful association.
            </p>
            <p>Sincerely,<br/><span t-out="company.name"/></p>
        </t>
    </template>

    <template id="letter_body_joining">
        <t t-call="employee_letter_wizard.letter_layout"/>
    </template>

    <template id="letter_body_promotion">
        <t t-call="employee_letter_wizard.letter_layout"/>
    </template>

    <template id="letter_body_resignation">
        <t t-call="employee_letter_wizard.letter_layout"/>
    </template>
</odoo>
