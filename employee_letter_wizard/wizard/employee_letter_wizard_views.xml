<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_letter_wizard_form" model="ir.ui.view">
        <field name="name">employee.letter.wizard.form</field>
        <field name="model">employee.letter.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Employee Letter">
                <group>
                    <field name="employee_id"/>
                    <field name="letter_type"/>
                </group>
                <field name="letter_html"/>
                <footer>
                    <button string="Generate PDF" type="object" name="action_generate_pdf" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_employee_letter_wizard" model="ir.actions.act_window">
        <field name="name">Generate Employee Letter</field>
        <field name="res_model">employee.letter.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu item under HR module -->
    <menuitem
        id="menu_employee_letter_wizard"
        name="Generate Employee Letter"
        action="action_employee_letter_wizard"
        parent="hr.menu_hr_root"
        sequence="50"
    />
</odoo>
